# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=*

# Postgres / Supabase
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/traderos
# Production (Supabase): postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Auth
JWT_SECRET=replace-me-with-a-long-random-secret-min-32-bytes
JWT_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# Investor password шифрі (AES-256-GCM, 32-byte hex/base64). Random keygen-мен жасаңыз.
INVESTOR_PWD_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Claude API (TZ.rtf: бар AI Claude-та)
ANTHROPIC_API_KEY=sk-ant-...

# Finnhub (live prices, news, calendar)
FINNHUB_API_KEY=

# Telegram bot — DROPPED. Signals/ideas published via admin panel.

# Push notifications — Firebase Cloud Messaging (Admin SDK service account)
# Firebase Console → Project Settings → Service accounts → Generate new private key.
# From that JSON: project_id, client_email, private_key.
# Keep the private key on ONE line with literal \n for line breaks, in quotes.
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Supabase Storage (chart screenshots, Kaspi receipts)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Admin panel login — set these on the server; on startup the backend creates/updates
# this user with is_admin=true. Log into the admin panel with this phone + password.
ADMIN_PHONE=+77000000000
ADMIN_PASSWORD=change-this-strong-password
